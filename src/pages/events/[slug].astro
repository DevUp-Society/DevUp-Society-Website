---
/**
 * /events/[slug].astro - Dynamic Event Detail Pages
 * 
 * SEO-optimized event pages with comprehensive structured data:
 * - Event schema for Google Events search results
 * - HackathonEvent schema for hackathon-specific features
 * - Offer schema for event pricing
 * - EducationalEvent schema for workshop content
 * - BreadcrumbList for navigation context
 * 
 * AEO Optimization:
 * - Structured FAQ sections per event
 * - Quotable event descriptions
 * - Clear dates, locations, and pricing
 * 
 * TARGET KEYWORDS:
 * - {event.title} + VJIT + hackathon
 * - DevUp Society events
 * - Student hackathon Hyderabad
 * - Coding competition India 2026
 */
import MainLayout from '../../layouts/MainLayout.astro';
import { events } from '../../data/events';
import { Icon } from 'astro-icon/components';

// Generate static paths for all events
export async function getStaticPaths() {
  return events.map((event) => ({
    params: { slug: event.slug },
    props: { event },
  }));
}

const { event } = Astro.props;

// Date helpers
const eventDate = new Date(event.date);
const formattedDate = eventDate.toLocaleDateString('en-US', {
  weekday: 'long',
  month: 'long',
  day: 'numeric',
  year: 'numeric',
});

// ISO format for schema
const isoDate = eventDate.toISOString();

const isUpcoming = event.status === 'upcoming';
const isFoundersMeet = event.slug === 'founders-meet-2026';

/**
 * Generate comprehensive Event schema for Google Events
 * Supports: Hackathon, Workshop, Conference, and general events
 */
const generateEventSchema = () => {
  const siteUrl = 'https://www.devupvjit.in';
  
  // Base Event schema (applicable to all events)
  const baseSchema = {
    "@context": "https://schema.org",
    "@type": event.isHackathon ? "Hackathon" : "Event",
    "name": event.title,
    "description": event.fullDescription,
    "url": `${siteUrl}/events/${event.slug}`,
    "startDate": isoDate,
    "endDate": event.isHackathon ? new Date(new Date(event.date).getTime() + 36 * 60 * 60 * 1000).toISOString() : isoDate,
    "eventStatus": event.status === 'upcoming' ? "https://schema.org/EventScheduled" : "https://schema.org/EventPostponed",
    "eventAttendanceMode": event.mode === 'Online' 
      ? "https://schema.org/OnlineEventAttendanceMode"
      : event.mode === 'Hybrid'
        ? "https://schema.org/MixedEventAttendanceMode"
        : "https://schema.org/OfflineEventAttendanceMode",
    "location": event.mode === 'Online' ? {
      "@type": "VirtualLocation",
      "url": `${siteUrl}/events/${event.slug}`
    } : {
      "@type": "Place",
      "name": event.location,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Aziz Nagar Gate",
        "addressLocality": "Hyderabad",
        "addressRegion": "Telangana",
        "postalCode": "500075",
        "addressCountry": "IN"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 17.3455,
        "longitude": 78.3236
      }
    },
    "image": event.images.length > 0 ? event.images : [`${siteUrl}/og-image.jpg`],
    "organizer": {
      "@type": "Organization",
      "name": "DevUp Society",
      "url": siteUrl,
      "logo": `${siteUrl}/logo.png`,
      "sameAs": [
        "https://www.linkedin.com/company/devup-community",
        "https://www.instagram.com/devupcommunity",
        "https://github.com/DevUp-Society"
      ]
    },
    "performer": event.speakers.length > 0 ? event.speakers.map(speaker => ({
      "@type": "Person",
      "name": speaker.name,
      "jobTitle": speaker.designation,
      "worksFor": speaker.company ? {
        "@type": "Organization",
        "name": speaker.company
      } : undefined
    })) : undefined,
    "offers": event.fee ? {
      "@type": "Offer",
      "price": event.fee,
      "priceCurrency": "INR",
      "availability": event.status === 'upcoming' ? "https://schema.org/InStock" : "https://schema.org/SoldOut",
      "validFrom": new Date().toISOString(),
      "url": `${siteUrl}/events/${event.slug}/register`
    } : {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "INR",
      "availability": "https://schema.org/InStock",
      "description": "Free registration"
    },
    "isAccessibleForFree": !event.fee,
    "inLanguage": "en",
    "keywords": event.tags.join(", ")
  };

  // Add hackathon-specific properties
  if (event.isHackathon && event.stats) {
    Object.assign(baseSchema, {
      "maximumAttendeeCapacity": parseInt(event.stats.participants.replace(/\D/g, '')) || 400,
      "about": event.themes ? event.themes.map(theme => ({
        "@type": "Thing",
        "name": theme.title,
        "description": theme.description
      })) : undefined,
      "workFeatured": event.prizes ? {
        "@type": "CreativeWork",
        "name": "Hackathon Project Submissions",
        "description": "Projects built during the hackathon",
        "award": event.prizes.map(prize => `${prize.type}: ${prize.amount}`).join(', ')
      } : undefined
    });
  }

  return baseSchema;
};

/**
 * Generate FAQ schema for event-specific FAQs
 */
const generateEventFaqSchema = () => {
  if (!event.faqs || event.faqs.length === 0) return null;
  
  return {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": event.faqs.map(faq => ({
      "@type": "Question",
      "name": faq.question,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": faq.answer
      }
    }))
  };
};

/**
 * Generate Breadcrumb schema for navigation
 */
const generateBreadcrumbSchema = () => {
  return {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "https://www.devupvjit.in"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Events",
        "item": "https://www.devupvjit.in/events"
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": event.title,
        "item": `https://www.devupvjit.in/events/${event.slug}`
      }
    ]
  };
};

// Combine all schemas
const eventSchema = generateEventSchema();
const faqSchema = generateEventFaqSchema();
const breadcrumbSchema = generateBreadcrumbSchema();

// Build combined schema array
const combinedSchema = faqSchema 
  ? [eventSchema, faqSchema, breadcrumbSchema]
  : [eventSchema, breadcrumbSchema];

// Generate SEO-optimized keywords
const eventKeywords = [
  event.title,
  "DevUp Society",
  event.isHackathon ? "hackathon" : "event",
  "VJIT",
  "Hyderabad",
  "student developer",
  ...event.tags
].join(", ");

// Generate meta description optimized for clicks
const metaDescription = event.isHackathon 
  ? `${event.title} - ${event.stats?.prizePool || ''} prize pool. ${event.shortDescription} Join ${event.stats?.participants || '400+'} developers at VJIT, Hyderabad.`
  : event.shortDescription;
---

<MainLayout 
  title={`${event.title} | DevUp Society - ${event.isHackathon ? 'Hackathon' : 'Event'} at VJIT`}
  description={metaDescription}
  keywords={eventKeywords}
  type="event"
  image={event.images.length > 0 ? event.images[0] : undefined}
  schema={combinedSchema}
>

  {/* ========================================== */}
  {/*           UPCOMING / HYPE LAYOUT           */}
  {/* ========================================== */}
  {isUpcoming ? (
    <>
      {isFoundersMeet && (
        <section class="relative bg-[#0b0b10] text-zinc-100 border-b border-red-500/30 pt-28 md:pt-32 pb-12 md:pb-16">
          <div class="max-w-6xl mx-auto px-6">
            <a href="/events" data-scroll-top class="inline-flex items-center gap-2 text-zinc-400 hover:text-red-300 font-mono text-xs uppercase tracking-widest transition-colors mb-5 md:mb-8">
              <Icon name="lucide:arrow-left" />
              <span>Back</span>
            </a>

            <div class="mb-5 md:mb-6 rounded-xl border border-red-500/30 bg-zinc-950 px-3 md:px-4 py-3">
              <div class="grid grid-cols-3 items-center gap-2 md:gap-4">
                <div class="flex justify-center">
                  <a href="https://startupsindia.in/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center">
                    <img src="https://res.cloudinary.com/dmrp1d1tv/image/upload/q_auto/f_auto/v1770106897/Startups_India_Logo_ba8vml.png" alt="Startup India" class="h-8 md:h-10 w-auto object-contain" loading="lazy" />
                  </a>
                </div>
                <div class="flex justify-center">
                  <a href="https://www.devupvjit.in/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center">
                    <img src="/favicon.png" alt="DevUp Society" class="h-10 md:h-11 w-auto object-contain" loading="lazy" />
                  </a>
                </div>
                <div class="flex justify-center">
                  <a href="https://t-hub.co/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center">
                    <img src="https://upload.wikimedia.org/wikipedia/commons/4/40/T-Hub_Logo-PNG.png" alt="T-HUB" class="h-8 md:h-10 w-auto object-contain" loading="lazy" />
                  </a>
                </div>
              </div>
              <div class="mt-3 grid grid-cols-3 gap-2 md:gap-3 text-center">
                <a href="https://startupsindia.in/" target="_blank" rel="noopener noreferrer" class="text-[10px] md:text-xs font-mono uppercase tracking-widest px-2 py-1 border border-red-500/40 text-red-300 hover:bg-red-500/10 transition-colors">startupsindia.in</a>
                <a href="https://www.devupvjit.in/" target="_blank" rel="noopener noreferrer" class="text-[10px] md:text-xs font-mono uppercase tracking-widest px-2 py-1 border border-red-500/40 text-red-300 hover:bg-red-500/10 transition-colors">devupvjit.in</a>
                <a href="https://t-hub.co/" target="_blank" rel="noopener noreferrer" class="text-[10px] md:text-xs font-mono uppercase tracking-widest px-2 py-1 border border-red-500/40 text-red-300 hover:bg-red-500/10 transition-colors">t-hub.co</a>
              </div>
            </div>

            <div class="rounded-2xl border border-red-500/30 bg-gradient-to-b from-zinc-950 to-zinc-900 p-5 md:p-10 shadow-[0_20px_80px_rgba(220,38,38,0.12)]">
              <p class="font-mono text-[10px] md:text-[11px] uppercase tracking-[0.2em] text-red-300 mb-3 md:mb-4">Flagship Founder Event</p>
              <h1 class="font-display text-4xl md:text-6xl font-bold tracking-tight text-red-300 mb-4">{event.title}</h1>
              <p class="text-base md:text-lg text-zinc-300 max-w-3xl leading-relaxed mb-6 md:mb-8">{event.shortDescription}</p>

              <div class="grid grid-cols-1 md:grid-cols-4 gap-3 md:gap-4 mb-7 md:mb-10">
                <div class="rounded-xl border border-red-500/30 bg-zinc-900 p-4">
                  <p class="font-mono text-[10px] uppercase tracking-widest text-zinc-400">Date</p>
                  <p class="text-sm font-semibold text-white">{formattedDate}</p>
                </div>
                <div class="rounded-xl border border-red-500/30 bg-zinc-900 p-4">
                  <p class="font-mono text-[10px] uppercase tracking-widest text-zinc-400">Venue</p>
                  <p class="text-sm font-semibold text-white">{event.location}</p>
                </div>
                <div class="rounded-xl border border-red-500/30 bg-zinc-900 p-4">
                  <p class="font-mono text-[10px] uppercase tracking-widest text-zinc-400">Seats</p>
                  <p class="text-sm font-semibold text-white">{event.seatsLeft ?? 'Limited'} Available</p>
                </div>
                <div class="rounded-xl border border-red-500/30 bg-zinc-900 p-4">
                  <p class="font-mono text-[10px] uppercase tracking-widest text-zinc-400">Format</p>
                  <p class="text-sm font-semibold text-white">Free Registration + Interview Selection</p>
                </div>
              </div>

              <div class="relative rounded-xl border border-red-500/30 bg-zinc-900 p-6 md:p-8 overflow-hidden">
                <div class="absolute -top-10 left-1/2 -translate-x-1/2 w-60 h-60 bg-red-500/20 blur-3xl pointer-events-none"></div>
                <div class="absolute inset-0 pointer-events-none" style="background-image: linear-gradient(rgba(239,68,68,0.08) 1px, transparent 1px), linear-gradient(90deg, rgba(239,68,68,0.08) 1px, transparent 1px); background-size: 26px 26px;"></div>

                <div class="relative flex flex-col items-center text-center gap-4">
                  <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-red-300 border border-red-500/40 px-3 py-1">Limited Founder Slots</span>
                  <h2 class="font-display text-2xl md:text-3xl font-bold text-white">Ready To Enter The Room?</h2>
                  <a href="/events/founders-meet-2026/register" class="group inline-flex items-center justify-center gap-3 min-w-[220px] px-8 py-4 bg-red-500 text-black font-mono text-xs md:text-sm font-bold tracking-widest uppercase hover:bg-red-400 transition-colors clip-corner btn-glitch border border-red-300 shadow-[0_0_35px_rgba(239,68,68,0.45)]">
                    Register Now
                    <Icon name="lucide:arrow-right" class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" />
                  </a>
                </div>
              </div>
            </div>
          </div>
        </section>
      )}

      {isFoundersMeet && (
        <section class="py-14 bg-[#0b0b10] border-b border-red-500/30">
          <div class="max-w-6xl mx-auto px-6 space-y-10">
            <div>
              <p class="font-mono text-[11px] uppercase tracking-[0.2em] text-zinc-400 mb-3">Main Poster</p>
              <div class="rounded-xl border border-red-500/30 bg-zinc-900 p-4 md:p-6 flex items-center justify-center">
                <img src="https://res.cloudinary.com/dmrp1d1tv/image/upload/q_auto/f_auto/v1775898652/Founders_Meet_Poster_lxwujw.png" alt="Founders Meet Main Poster" class="w-full max-w-3xl h-auto object-contain" loading="eager" />
              </div>
            </div>

            <div>
              <p class="font-mono text-[11px] uppercase tracking-[0.2em] text-zinc-400 mb-3">Timeline Poster</p>
              <div class="rounded-xl border border-red-500/30 bg-zinc-900 p-4 md:p-6 flex items-center justify-center">
                <img src="https://res.cloudinary.com/dmrp1d1tv/image/upload/q_auto/f_auto/v1775898653/Timeline_zsbyuj.png" alt="Founders Meet Timeline Poster" class="w-full max-w-3xl h-auto object-contain" loading="lazy" />
              </div>
            </div>

            {event.timeline && (
              <div>
                <p class="font-mono text-[11px] uppercase tracking-[0.2em] text-zinc-400 mb-3">Timeline</p>
                <div class="relative space-y-8 before:absolute before:left-4 md:before:left-1/2 before:top-0 before:h-full before:w-px before:bg-red-500/30">
                  {event.timeline.map((item, index) => (
                    <div class={`relative flex items-start md:items-center ${index % 2 === 0 ? 'md:flex-row' : 'md:flex-row-reverse'}`}>
                      <div class="absolute left-4 md:left-1/2 -translate-x-1/2 w-3 h-3 rounded-full bg-red-500 border-2 border-zinc-950 shadow"></div>
                      <div class="ml-10 md:ml-0 md:w-[calc(50%-2rem)] rounded-xl border border-red-500/30 bg-zinc-900 p-4 md:p-5 shadow-sm">
                        <div class="flex items-center justify-between gap-3 mb-1">
                          <h3 class="font-semibold text-zinc-100">{item.title}</h3>
                          <span class="inline-flex px-2.5 py-1 rounded-full bg-red-500/20 text-red-300 text-[10px] font-mono uppercase tracking-widest">{item.date}</span>
                        </div>
                        <p class="text-sm text-zinc-300">{item.description}</p>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            )}

            <div>
              <p class="font-mono text-[11px] uppercase tracking-[0.2em] text-zinc-400 mb-3">Main Organizer</p>
              <div class="rounded-xl border border-red-500/30 bg-zinc-900 p-6 flex items-center justify-center">
                <div class="w-full max-w-md rounded-lg bg-zinc-900 p-4 flex items-center justify-center">
                  <img src="https://res.cloudinary.com/dmrp1d1tv/image/upload/q_auto/f_auto/v1770106897/Startups_India_Logo_ba8vml.png" alt="Startup India" class="h-14 md:h-16 w-auto object-contain" loading="lazy" />
                </div>
              </div>
            </div>

            <div>
              <p class="font-mono text-[11px] uppercase tracking-[0.2em] text-zinc-400 mb-3">Venue Ecosystem</p>
              <div class="rounded-xl border border-red-500/30 bg-zinc-900 p-6 flex items-center justify-center">
                <div class="w-full max-w-md rounded-lg bg-zinc-900 p-4 flex items-center justify-center">
                  <img src="https://upload.wikimedia.org/wikipedia/commons/4/40/T-Hub_Logo-PNG.png" alt="T-HUB" class="h-14 md:h-16 w-auto object-contain" loading="lazy" />
                </div>
              </div>
            </div>

            <div>
              <p class="font-mono text-[11px] uppercase tracking-[0.2em] text-zinc-400 mb-3">Associate Partners</p>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div class="rounded-xl border border-red-500/30 bg-zinc-900 p-6 flex items-center justify-center">
                  <div class="w-full rounded-lg bg-zinc-900 p-4 flex items-center justify-center">
                    <img src="/favicon.png" alt="DevUp Society" class="h-12 w-auto object-contain" loading="lazy" />
                  </div>
                </div>
                <div class="rounded-xl border border-red-500/30 bg-zinc-900 p-6 flex items-center justify-center">
                  <div class="w-full rounded-lg bg-zinc-900 p-4 flex items-center justify-center">
                    <img src="https://res.cloudinary.com/dmrp1d1tv/image/upload/q_auto/f_auto/v1770106897/IEC-Logo_cxbv77.png" alt="I and EC" class="h-12 w-auto object-contain" loading="lazy" />
                  </div>
                </div>
              </div>
            </div>

            <div>
              <div class="flex items-center justify-between mb-3">
                <p class="font-mono text-[11px] uppercase tracking-[0.2em] text-zinc-400">Collaboration Highlights</p>
                <span class="text-xs text-zinc-400">Swipe</span>
              </div>
              <div class="flex gap-4 overflow-x-auto pb-2">
                <a href="https://startupsindia.in/" target="_blank" rel="noopener noreferrer" class="min-w-[260px] rounded-xl border border-red-500/30 bg-zinc-900 p-5 hover:border-red-400 transition-colors">
                  <h3 class="font-semibold text-zinc-100 mb-1">Startup Ecosystem Connect</h3>
                  <p class="text-sm text-zinc-300">Opportunity mapping with startup community pathways.</p>
                </a>
                <a href="https://t-hub.co/" target="_blank" rel="noopener noreferrer" class="min-w-[260px] rounded-xl border border-red-500/30 bg-zinc-900 p-5 hover:border-red-400 transition-colors">
                  <h3 class="font-semibold text-zinc-100 mb-1">T-HUB Network Access</h3>
                  <p class="text-sm text-zinc-300">Founder exposure and ecosystem-level interaction opportunities.</p>
                </a>
                <div class="min-w-[260px] rounded-xl border border-red-500/30 bg-zinc-900 p-5">
                  <h3 class="font-semibold text-zinc-100 mb-1">Mentor & Community Connect</h3>
                  <p class="text-sm text-zinc-300">Focused support with partner communities and domain mentors.</p>
                </div>
              </div>
            </div>

            {event.mapEmbedLink && (
              <div>
                <p class="font-mono text-[11px] uppercase tracking-[0.2em] text-zinc-400 mb-3">Venue Map</p>
                <div class="rounded-xl border border-red-500/30 bg-zinc-900 p-3 md:p-4">
                  <div class="w-full h-[320px] md:h-[420px] overflow-hidden rounded-lg border border-red-500/20">
                    <iframe
                      src={event.mapEmbedLink}
                      title={`${event.title} venue map`}
                      width="100%"
                      height="100%"
                      style="border:0;"
                      loading="lazy"
                      referrerpolicy="no-referrer-when-downgrade"
                    ></iframe>
                  </div>
                  <div class="mt-4 flex items-center justify-between gap-3 flex-wrap">
                    <p class="text-sm text-zinc-300">Venue: {event.location}</p>
                    <a href="https://maps.app.goo.gl/c4umsMpk6xYw3rcF8" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg border border-red-500/40 text-red-300 hover:bg-red-500/10 transition-colors text-sm font-medium">
                      Open in Google Maps
                      <Icon name="lucide:external-link" class="w-4 h-4" />
                    </a>
                  </div>
                </div>
              </div>
            )}

            {event.faqs && (
              <div>
                <p class="font-mono text-[11px] uppercase tracking-[0.2em] text-zinc-400 mb-3">FAQs</p>
                <div class="space-y-3">
                  {event.faqs.map((faq) => (
                    <details class="group rounded-xl border border-red-500/30 bg-zinc-900 open:border-red-400 transition-colors">
                      <summary class="flex items-center justify-between p-4 cursor-pointer list-none text-zinc-100 font-medium">
                        {faq.question}
                        <Icon name="lucide:chevron-down" class="w-4 h-4 text-red-600 group-open:rotate-180 transition-transform" />
                      </summary>
                      <div class="px-4 pb-4 text-sm text-zinc-300 border-t border-red-500/20 pt-3">
                        {faq.answer}
                      </div>
                    </details>
                  ))}
                </div>
              </div>
            )}
          </div>
        </section>
      )}

      <div class={isFoundersMeet ? 'hidden' : ''}>
      <!-- HERO SECTION (HYPE) -->
      <section class="relative min-h-screen w-full flex flex-col justify-center items-center overflow-hidden border-b border-zinc-900 pt-32 pb-20">
        <div class="grid-floor opacity-40 fixed inset-0 z-0"></div>
        <div class="absolute inset-0 bg-gradient-to-b from-transparent via-void/50 to-void z-10 pointer-events-none"></div>

        <!-- Back Button -->
        <a href="/events" data-scroll-top class="absolute top-32 left-6 z-30 inline-flex items-center gap-2 text-zinc-400 hover:text-signal font-mono text-xs uppercase tracking-widest transition-colors">
          <Icon name="lucide:arrow-left" />
          <span>Back</span>
        </a>

        <div class="relative z-20 text-center px-4 max-w-5xl mx-auto">
          <!-- Countdown (Placeholder for simple logic, can be componentized) -->
          <div class="mb-8 inline-flex items-center gap-2 px-4 py-2 border border-signal bg-signal/10 clip-corner animate-pulse">
            <Icon name="lucide:timer" class="text-signal" />
            <span class="font-mono text-signal text-sm font-bold tracking-widest uppercase">
               Starts {formattedDate}
            </span>
          </div>

          <h1 class="font-display text-5xl md:text-8xl text-white font-bold leading-[0.85] tracking-tight mb-8 text-stroke-white">
            {event.title}
          </h1>

          <p class="font-mono text-zinc-400 text-sm md:text-base max-w-2xl mx-auto leading-relaxed mb-12">
            {event.shortDescription}
          </p>

          <div class="flex flex-wrap items-center justify-center gap-3 mb-10">
            <span class="px-3 py-1 border border-zinc-800 bg-black/40 font-mono text-[10px] text-zinc-300 uppercase tracking-widest">
              {event.location}
            </span>
            {event.seatsLeft && (
