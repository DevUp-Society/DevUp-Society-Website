<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    if ('scrollRestoration' in window.history) {
      window.history.scrollRestoration = 'manual';
    }

    window.scrollTo({ top: 0, behavior: 'auto' });

    document.querySelectorAll('[data-scroll-top]').forEach((link) => {
      link.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    });
  });
</script>

{isFoundersMeet && (
  <script is:inline>
    (function () {
      const el = document.getElementById('pitchquest-countdown');
      if (!el) return;

      const closeDate = new Date('2026-04-11T23:59:59+05:30');

      const updateCountdown = () => {
        const now = new Date();
        const diff = closeDate.getTime() - now.getTime();

        if (diff <= 0) {
          el.textContent = 'Registrations closed';
          return;
        }

        const days = Math.floor(diff / (1000 * 60 * 60 * 24));
        const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
        const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
        el.textContent = `Registrations close in ${days}d ${hours}h ${minutes}m`;
      };

      updateCountdown();
      setInterval(updateCountdown, 60000);
    })();
  </script>
)}
