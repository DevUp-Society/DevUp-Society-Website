rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    match /attachments/{allPaths=**} {
      allow read: if signedIn();
      allow write: if signedIn() && request.resource.size < 10 * 1024 * 1024;
    }
  }
}
